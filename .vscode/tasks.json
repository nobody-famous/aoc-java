{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile",
            "type": "shell",
            "command": "mvn",
            "args": ["-B", "compile"],
            "problemMatcher": []
        },
        {
            "label": "Run",
            "dependsOn": "Compile",
            "type": "shell",
            "command": "mvn",
            "windows": {
                "args": ["exec:java", "-D'\"exec.mainClass\"'='\"aoc.Runner\"'"]
            },
            "linux": {
                "args": ["exec:java", "-Dexec.mainClass=aoc.Runner"]
            },
            "problemMatcher": []
        },
        {
            "label": "Unit Tests",
            "dependsOn": "Compile",
            "type": "shell",
            "command": "mvn",
            "args": ["test"],
            "problemMatcher": []
        },
        {
            "label": "Test 2024",
            "dependsOn": "Compile",
            "type": "shell",
            "command": "mvn",
            "windows": {
                "args": ["test", "-D'test=aoc.y2024.day16.**'"]
            },
            "linux": {
                "args": ["test", "-Dtest=aoc.y2024.day16.**"]
            },
            "problemMatcher": []
        },
        {
            "label": "DB Update",
            "type": "shell",
            "command": "mvn",
            "args": ["liquibase:update"],
            "problemMatcher": []
        },
        {
            "label": "DB Rollback",
            "type": "shell",
            "command": "mvn",
            "linux": {
                "args": ["liquibase:rollback", "-Dliquibase.rollbackCount=1"]
            },
            "windows": {
                "args": ["liquibase:rollback", "-D'liquibase.rollbackCount'=1"]
            },
            "problemMatcher": []
        },
        {
            "label": "Start DB Docker",
            "type": "shell",
            "command": "docker",
            "args": [
                "run",
                "--name",
                "aoc-postgres",
                "--rm",
                "-it",
                "-e",
                "POSTGRES_PASSWORD=postgres",
                "-v",
                "${workspaceFolder}/db-data:/var/lib/postgresql/data",
                "-p",
                "5432:5432",
                "postgres"
            ],
            "problemMatcher": []
        }
    ]
}
